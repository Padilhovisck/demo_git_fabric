	measure IVP = ```
			
			VAR DocsNoPeriodo =
			    FILTER(
			        fDocumentos,
			        fDocumentos[DataConsulta] >= MIN(dCalendario[Data]) &&
			        fDocumentos[DataConsulta] <= MAX(dCalendario[Data])
			    )
			VAR ConsultasAntesVencimento =
			    COUNTROWS(
			        FILTER(
			            DocsNoPeriodo,
			            RELATED(dNotas[PrimeiraDataConsulta]) > fDocumentos[DataVencimento]
			        )
			    )
			VAR TotalConsultas =
			    COUNTROWS(DocsNoPeriodo)
			RETURN
			DIVIDE(ConsultasAntesVencimento, TotalConsultas)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Notas Fiscais\Consultas

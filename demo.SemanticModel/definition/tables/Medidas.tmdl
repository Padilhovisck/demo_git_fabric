			VAR RaizFiltro = 
			    IF(
			        NOT ISBLANK(EmitenteSelecionado),
			        CALCULATE(
			            MIN(fCarteira[CnpjCedenteRaiz]),
			            fCarteira[NomeCedente] = EmitenteSelecionado
			        ),
			        BLANK()
			    )
			
			RETURN
			    IF(
			        TipoSelecionado = "Grupo" && NOT ISBLANK(RaizFiltro),
			        RaizFiltro,
			        BLANK()
			    )
			```
		displayFolder: _Auxiliares\Contexto e Filtros
		lineageTag: 18e0ba85-3ad2-4076-8325-294e5bdad104


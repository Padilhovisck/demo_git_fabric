	/// Valor total da carteira considerando apenas notas consultadas que possuem eventos. Cruzamento de consultas e eventos.
	measure 'Total Carteira Eventos Notas Consultadas' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer_Notas[Emitente])
			
			VAR FiltroNotas = 
			    FILTER(
			        fCarteira,
			        RELATED(dNotas[ChaveNotaFiscal]) <> BLANK()
			    )
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = "Grupo" && NOT(ISBLANK(RaizContexto)),
			        // Modo Grupo: filtra pela raiz
			        CALCULATE(
			            SUM(fCarteira[Valor]),
			            FILTER(
			                FiltroNotas,
			                fCarteira[CnpjCedenteRaiz] = RaizContexto
			            )
			        ),
			        // Modo Individual: aplica filtro do emitente selecionado
			        IF(
			            NOT(ISBLANK(EmitenteSelecionado)),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FILTER(
			                    FiltroNotas,
			                    fCarteira[NomeCedente] = EmitenteSelecionado
			                )
			            ),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FiltroNotas
			            )
			        )
			    )
			
			RETURN COALESCE(Resultado, 0)
			```
		displayFolder: Eventos\Valores
		lineageTag: a9ec3d22-c26e-4b5d-b750-a674e93f4f83

		annotation PBI_FormatHint = {"isGeneralNumber":true}


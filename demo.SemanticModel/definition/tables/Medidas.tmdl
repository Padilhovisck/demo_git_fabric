	/// Percentual do código de evento 210200 dentro dos eventos positivos. Métrica específica de tipo de evento.
	measure '% Código 210200 dentro do Positivo' = ```
			
			VAR TotalPositivo =
			    CALCULATE(
			        [Teste Total Carteira por Último Evento],
			        REMOVEFILTERS(dEventos[CodigoEvento])
			    )
			
			VAR Total210200 =
			    CALCULATE(
			        [Teste Total Carteira por Último Evento],
			        dEventos[CodigoEvento] = "210200"
			    )
			
			RETURN
			DIVIDE(Total210200, TotalPositivo)
			

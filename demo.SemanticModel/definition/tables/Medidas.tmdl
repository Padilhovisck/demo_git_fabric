	measure 'Tempo Médio de Confirmação' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			
			VAR _NotasComEventoPreponderante = 
			    FILTER(
			        dNotas,
			        NOT(ISBLANK(dNotas[UltimoEvento])) &&
			        NOT(ISBLANK(dNotas[DataEmissao])) &&
			        NOT(ISBLANK(dNotas[UltimaDataConsulta])) &&
			        (
			            (dNotas[PrimeiraDataConsulta] >= MinDataFiltrada && dNotas[PrimeiraDataConsulta] <= MaxDataFiltrada) ||
			            (dNotas[UltimaDataConsulta] >= MinDataFiltrada && dNotas[UltimaDataConsulta] <= MaxDataFiltrada)
			        )
			    )
			
			VAR _NotasValidas = 
			    FILTER(
			        _NotasComEventoPreponderante,
			        RELATED(dEventos[PreponderanciaCodigo]) = 1
			    )
			
			VAR _TotalDias = 
			    SUMX(
			        _NotasValidas,
			        DATEDIFF(
			            dNotas[DataEmissao],
			            dNotas[UltimaDataConsulta],
			            DAY
			        )
			    )
			
			VAR _Quantidade = 
			    COUNTROWS(_NotasValidas)
			
			VAR _MediaDias = 
			    DIVIDE(_TotalDias, _Quantidade, BLANK())
			
			RETURN
			    _MediaDias
			```
		displayFolder: Eventos\Análise
		lineageTag: 46aa125e-7e4c-49f3-b300-0abefd386854

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Média Eventos por Nota Tempo' = ```
			
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			
			VAR _totalEventos = 
			    CALCULATE(
			        COUNTROWS(fEventos),
			        FILTER(
			            fEventos,            
			            (RELATED(dNotas[PrimeiraDataConsulta]) >= MinDataFiltrada && RELATED(dNotas[PrimeiraDataConsulta]) <= MaxDataFiltrada) ||
			            (RELATED(dNotas[UltimaDataConsulta]) >= MinDataFiltrada && RELATED(dNotas[UltimaDataConsulta]) <= MaxDataFiltrada)
			        )
			    )
			
			VAR _notasNoTempo = 
			    CALCULATE(
			        DISTINCTCOUNT(fEventos[ChaveNotaFiscal]),
			        FILTER(
			            fEventos,
			            (RELATED(dNotas[PrimeiraDataConsulta]) >= MinDataFiltrada && 
			             RELATED(dNotas[PrimeiraDataConsulta]) <= MaxDataFiltrada) ||
			            (RELATED(dNotas[UltimaDataConsulta]) >= MinDataFiltrada && 
			             RELATED(dNotas[UltimaDataConsulta]) <= MaxDataFiltrada)
			        )
			    )
			
			RETURN
			    ROUND(
			        DIVIDE(
			            _totalEventos,
			            _notasNoTempo,
			            0
			        ),
			        2
			    )
			```
		displayFolder: Eventos\Análise
		lineageTag: 986cbfac-8b59-421b-bf2a-bf5ad6b64f4a

		annotation PBI_FormatHint = {"isGeneralNumber":true}


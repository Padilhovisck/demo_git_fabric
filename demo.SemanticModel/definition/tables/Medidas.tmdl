	/// Percentual de notas a vencer no período selecionado. Indica liquidez futura.
	measure '% Total a Vencer no Período' =
			
			VAR ResultadoPercentual = DIVIDE([Total a Vencer no Período], [Total de Consultas Realizadas], 0)
			RETURN
			    "(a vencer) | " & FORMAT(ResultadoPercentual, "0.0%")
		displayFolder: Notas Fiscais\Status
		lineageTag: 69fdfff1-2a6c-4552-809f-b2625e5e49bc

	/// Prazo médio em dias para recebimento das NFes. Indicador de ciclo financeiro.
	measure 'Média Dias para Recebimento' = ```
			
			VAR TotalDocumentos = COUNTROWS(fDocumentos)
			VAR SomaDias = 
			    SUMX(
			        fDocumentos,
			        DATEDIFF(fDocumentos[DataVencimento], fDocumentos[DataConsulta], DAY)
			    )
			RETURN
			DIVIDE(SomaDias, TotalDocumentos, 0)
			```
		displayFolder: Notas Fiscais\Análise Temporal
		lineageTag: 578bca57-4df7-4633-8459-b66885f229c9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Quantidade total de notas fiscais na base. Contagem geral.
	measure 'Qtd Total de Notas' =
			
			VAR UltimaDataContexto = MAX(dCalendario[Data])
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(fDocumentos[ChaveNotaFiscal]),
			    fDocumentos[DataConsulta] < UltimaDataContexto
			)
		formatString: 0
		displayFolder: Notas Fiscais\Quantidades
		lineageTag: a6325fd3-1c39-480b-b9e6-bb9df25f103e

	/// Quantidade de notas que tiveram consulta realizada. Indicador de cobertura.
	measure 'Qtd Notas Consultadas' =
			
			COALESCE(
			    CALCULATE(
			        [Qtd Notas Primeira Consulta],
			        NOT(ISBLANK(dNotas[PrimeiraDataConsulta]))
			    ), 0
			)
		formatString: 0
		displayFolder: Notas Fiscais\Consultas
		lineageTag: e1a052da-2fa9-46cf-91aa-87e822ca7efe

	/// Percentual de notas consultadas sobre o total. KPI de cobertura operacional.
	measure '% Notas Consultadas' =
			
			VAR ResultadoPercentual = DIVIDE([Qtd Notas Consultadas], [Qtd Notas Primeira Consulta], 0)
			RETURN
			    "(consultadas) | " & FORMAT(ResultadoPercentual, "0.0%")
		displayFolder: Notas Fiscais\Consultas
		lineageTag: 7ba91891-61b5-4a52-942d-2a866b77d9b8

	/// Quantidade de notas que receberam a primeira consulta. Indicador de novas análises.
	measure 'Qtd Notas Primeira Consulta' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN 
			    CALCULATE(
			        COUNT(dNotas[ChaveNotaFiscal]),
			        dNotas[PrimeiraDataConsulta] >= MinDataFiltrada && 
			        dNotas[PrimeiraDataConsulta] <= MaxDataFiltrada &&
			        NOT(ISBLANK(dNotas[PrimeiraDataConsulta]))
			    )
			
			```
		formatString: 0
		displayFolder: Notas Fiscais\Consultas
		lineageTag: ca867aca-ce3c-4ac7-a078-9aa110209fca

	/// Tempo médio em dias entre consultas sucessivas de uma mesma nota. Frequência de acompanhamento.
	measure 'Média Dias Entre Consultas' = ```
			
			VAR TabelaFiltrada = 
			    FILTER(
			        dNotas,
			        NOT ISBLANK(dNotas[PrimeiraDataConsulta]) && 
			        NOT ISBLANK(dNotas[UltimaDataConsulta]) &&
			        dNotas[PrimeiraDataConsulta] <> dNotas[UltimaDataConsulta]
			    )
			RETURN
			AVERAGEX(
			    TabelaFiltrada,
			    DATEDIFF(dNotas[PrimeiraDataConsulta], dNotas[UltimaDataConsulta], DAY)
			)
			```
		displayFolder: Notas Fiscais\Análise Temporal
		lineageTag: e7dc262f-905a-4eea-aa5b-8b2be9a988d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Quantidade de notas que foram consultadas mais de uma vez. Indica retrabalho ou monitoramento.
	measure 'Qtd Notas com Múltiplas Consultas' = ```
			
			CALCULATE(
			    COUNTROWS(dNotas),
			    NOT ISBLANK(dNotas[PrimeiraDataConsulta]) && 
			    NOT ISBLANK(dNotas[UltimaDataConsulta]) &&
			    dNotas[PrimeiraDataConsulta] <> dNotas[UltimaDataConsulta]
			)
			```
		formatString: 0
		displayFolder: Notas Fiscais\Consultas
		lineageTag: c92eeb0d-b39b-45f9-a971-90b9febdfe14

	/// Quantidade total de notas no período filtrado. Análise temporal.
	measure 'Qtd Total de Notas no Período' =
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT(dNotas[ChaveNotaFiscal]),
			        FILTER(
			            dNotas,
			            (dNotas[PrimeiraDataConsulta] >= MinDataFiltrada && dNotas[PrimeiraDataConsulta] <= MaxDataFiltrada) ||
			            (dNotas[UltimaDataConsulta] >= MinDataFiltrada && dNotas[UltimaDataConsulta] <= MaxDataFiltrada)
			        )
			    )
		formatString: 0
		displayFolder: Notas Fiscais\Quantidades
		lineageTag: 6c23370a-796c-460f-aec2-91cd8686b013

	/// Quantidade de notas consultadas pela primeira vez no período selecionado.
	measure 'Qtd Notas Primeira Consulta no Período' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN 
			    CALCULATE(
			        DISTINCTCOUNT(dNotas[ChaveNotaFiscal]),
			        dNotas[PrimeiraDataConsulta] >= MinDataFiltrada && 
			        dNotas[PrimeiraDataConsulta] <= MaxDataFiltrada &&
			        NOT(ISBLANK(dNotas[PrimeiraDataConsulta]))
			    )
			
			```
		formatString: 0
		displayFolder: Notas Fiscais\Consultas
		lineageTag: 08dccaba-c6c7-4f24-9a7a-77643d60c133

	/// Quantidade de notas cuja última consulta ocorreu no período selecionado.
	measure 'Qtd Notas Última Consulta no Período' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN 
			    CALCULATE(
			        DISTINCTCOUNT(dNotas[ChaveNotaFiscal]),
			        dNotas[UltimaDataConsulta] >= MinDataFiltrada && 
			        dNotas[UltimaDataConsulta] <= MaxDataFiltrada &&
			        NOT(ISBLANK(dNotas[UltimaDataConsulta]))
			    )
			
			```
		formatString: 0
		displayFolder: Notas Fiscais\Consultas
		lineageTag: 241e801b-e725-4838-b632-53e9b1a24b0e

	/// Tempo médio entre a primeira e última consulta de notas. Ciclo de acompanhamento.
	measure 'Média Dias Primeira à Última Consulta' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN
			    AVERAGEX(
			        FILTER(
			            dNotas,
			            NOT(ISBLANK(dNotas[PrimeiraDataConsulta])) && 
			            NOT(ISBLANK(dNotas[UltimaDataConsulta])) &&
			            dNotas[PrimeiraDataConsulta] <> dNotas[UltimaDataConsulta] && -- Apenas notas com mais de uma consulta
			            dNotas[UltimaDataConsulta] >= MinDataFiltrada && -- Última consulta no período
			            dNotas[UltimaDataConsulta] <= MaxDataFiltrada
			        ),
			        DATEDIFF(dNotas[PrimeiraDataConsulta], dNotas[UltimaDataConsulta], DAY)
			    )
			
			```
		formatString: 0.0
		displayFolder: Notas Fiscais\Análise Temporal
		lineageTag: 1f6ed3da-5d66-4a1c-a10e-42532cdf52cb

	/// Quantos dias em média desde a primeira consulta até o fim do período. Indica antiguidade.
	measure 'Média Idade Primeira Consulta (Dias)' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN
			    AVERAGEX(
			        FILTER(
			            dNotas,
			            NOT(ISBLANK(dNotas[PrimeiraDataConsulta])) &&
			            dNotas[PrimeiraDataConsulta] <= MaxDataFiltrada && -- Apenas notas cuja primeira consulta ocorreu até a data final do contexto
			            (dNotas[PrimeiraDataConsulta] >= MinDataFiltrada || dNotas[UltimaDataConsulta] >= MinDataFiltrada) -- Garante que a nota teve alguma atividade no período
			        ),
			        DATEDIFF(dNotas[PrimeiraDataConsulta], MaxDataFiltrada, DAY)
			    )
			
			```
		formatString: 0.0
		displayFolder: Notas Fiscais\Análise Temporal
		lineageTag: a286dc8b-adc7-4ec8-a06a-36ee7ee95fc9

	/// Quantidade de notas consultadas mais de uma vez no período. Monitoramento intensivo.
	measure 'Qtd Notas Múltiplas Consultas no Período' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT(dNotas[ChaveNotaFiscal]),
			        NOT(ISBLANK(dNotas[PrimeiraDataConsulta])) && 
			        NOT(ISBLANK(dNotas[UltimaDataConsulta])) &&
			        dNotas[PrimeiraDataConsulta] <> dNotas[UltimaDataConsulta] && -- Apenas notas com mais de uma consulta
			        dNotas[UltimaDataConsulta] >= MinDataFiltrada && -- Última consulta no período
			        dNotas[UltimaDataConsulta] <= MaxDataFiltrada
			    )
			
			```
		formatString: 0
		displayFolder: Notas Fiscais\Consultas
		lineageTag: 4e0fd9ec-bbd1-483b-876a-45f0ed4db496

	/// Percentual de notas cuja última consulta foi no período. Atividade recente.
	measure '% Notas Última Consulta' = DIVIDE([Qtd Notas Última Consulta no Período], [Qtd Total de Notas no Período])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Notas Fiscais\Consultas
		lineageTag: bb39e285-3cf3-4d09-88ab-20cbd4cb9ba5

	/// Quantidade de notas consultadas pela primeira vez (histórico completo).
	measure 'Qtd Notas Consultadas Primeira Vez' =
			
			VAR MesSelecionado = SELECTEDVALUE('Selecionar Mês (Notas Primeira Vez)'[Selecionar Mês], 12)
			VAR MesAtual = MAX(dCalendario[MesNo])
			VAR AnoAtual = MAX(dCalendario[Ano])
			VAR AnoSelecionado = SELECTEDVALUE(dCalendario[Ano], YEAR(TODAY()))
			VAR _QtdeGeral = [Qtd Total de Notas no Período]
			VAR _QtdeNoPeriodo = [Qtd Notas Primeira Consulta no Período]
			VAR _Resultado = DIVIDE(_QtdeNoPeriodo, _QtdeGeral, 0)
			RETURN
			    IF(
			        AnoAtual = AnoSelecionado && MesAtual <= MesSelecionado,
			        _Resultado,  -- ✅ MUDANÇA AQUI: retorna o percentual em vez da quantidade
			        BLANK()
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Notas Fiscais\Consultas
		lineageTag: 65e88a09-3a56-437c-96c5-a9906bc86dd9

	/// Percentual de notas com múltiplas consultas no período. Taxa de retrabalho.
	measure '% Notas Múltiplas Consultas no Período' = DIVIDE([Qtd Notas Múltiplas Consultas no Período], [Qtd Total de Notas no Período])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Notas Fiscais\Consultas
		lineageTag: c00f3eff-c4b7-4942-afba-01e6b02e4ed5


			    ISINSCOPE(dNotas[NomeFantasiaEmitente]),
			    CALCULATE(
			        MAX(dNotas[UltimaDataConsulta]),
			        FILTER(
			            dNotas,            
			            (dNotas[UltimaDataConsulta] >= MinDataFiltrada && dNotas[UltimaDataConsulta] <= MaxDataFiltrada)
			        )

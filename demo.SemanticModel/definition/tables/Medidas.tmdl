	/// [Auxiliar] Formatação condicional para status de pendência. Alerta visual de itens pendentes.
	measure '_Formatação Condicional Pendência' = ```
			
			VAR _descricao = SELECTEDVALUE(dEventos[EventoPendentes])
			return 
			SWITCH(
			    TRUE(),
			    _descricao = "Confirmação (encerrado)", 0,
			    _descricao = "Positivo Avaliar", 1,
			    _descricao = "Negativo Avaliar", 2,
			    _descricao = "Negativo Crítico", 3,   
			    0
			)
			

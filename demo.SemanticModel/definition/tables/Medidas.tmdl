	/// Medida dinâmica de quantidade que alterna entre diferentes contagens com base em seleções do usuário.
	measure 'Qtd Dinâmica' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = "Grupo" && NOT(ISBLANK(RaizContexto)),
			        // Modo Grupo: calcula pela raiz filtrada
			        CALCULATE(
			            [Qtd Recebíveis],
			            REMOVEFILTERS(fCarteira[NomeCedente]),
			            fCarteira[CnpjCedenteRaiz] = RaizContexto
			        ),
			        // Modo Individual: aplica filtro do emitente selecionado
			        IF(
			            NOT(ISBLANK(EmitenteSelecionado)),
			            CALCULATE(
			                [Qtd Recebíveis],
			                fCarteira[NomeCedente] = EmitenteSelecionado
			            ),
			            [Qtd Recebíveis]
			        )
			    )
			
			RETURN Resultado
			```
		displayFolder: Carteira\Quantidades
		lineageTag: 4329549c-f5fd-435d-b626-730feed39834

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// [Auxiliar] Filtro aplicado em tabelas matriciais. Controle de exibição dinâmica.
	measure '_Filtro Tabela Matriz' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			// Pega TODAS as raízes visíveis no contexto atual
			VAR RaizesVisiveis = VALUES(fCarteira[CnpjCedenteRaiz])
			VAR CedentesVisiveis = VALUES(fCarteira[NomeCedente])
			
			// Raiz do emitente selecionado
			VAR RaizSelecionada = 
			    IF(
			        NOT(ISBLANK(EmitenteSelecionado)),
			        MAXX(
			            FILTER(
			                ALL(fCarteira[NomeCedente], fCarteira[CnpjCedenteRaiz]),
			                fCarteira[NomeCedente] = EmitenteSelecionado
			            ),
			            fCarteira[CnpjCedenteRaiz]
			        ),
			        BLANK()
			    )
			
			VAR Mostrar = 
			    IF(
			        ISBLANK(EmitenteSelecionado),
			        1, // Sem filtro
			        IF(
			            TipoSelecionado = "Grupo",
			            // Verifica se ALGUMA raiz visível é igual à selecionada
			            IF(RaizSelecionada IN RaizesVisiveis, 1, BLANK()),
			            // Individual: verifica se o cedente selecionado está visível
			            IF(EmitenteSelecionado IN CedentesVisiveis, 1, BLANK())
			        )
			    )
			
			RETURN Mostrar
			```
		formatString: 0
		displayFolder: _Auxiliares\Contexto e Filtros
		lineageTag: fef7cb2f-9639-4677-96da-c8c01a7e5f82

	/// Quantidade de recebíveis que tiveram suas NFes consultadas. Permite calcular taxa de consulta.
	measure 'Qtd Recebíveis Notas Consultadas' =
			
			CALCULATE(
			    [Qtd Recebíveis],
			    FILTER(
			        fCarteira,
			        RELATED(dNotas[ChaveNotaFiscal]) <> BLANK()
			    )
			)
		formatString: 0
		displayFolder: Carteira\Quantidades
		lineageTag: b2214289-9d81-46f0-b954-5ba79b4da066

	/// Versão dinâmica da quantidade de recebíveis, ajustando-se conforme seleções do usuário.
	measure 'Qtd Recebíveis Dinâmica' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = "Grupo" && NOT(ISBLANK(RaizContexto)),
			        // Modo Grupo: calcula pela raiz filtrada
			        CALCULATE(
			            [Qtd Recebíveis Notas Consultadas],
			            REMOVEFILTERS(fCarteira[NomeCedente]),
			            fCarteira[CnpjCedenteRaiz] = RaizContexto
			        ),
			        // Modo Individual: aplica filtro do emitente selecionado
			        IF(
			            NOT(ISBLANK(EmitenteSelecionado)),
			            CALCULATE(
			                [Qtd Recebíveis Notas Consultadas],
			                fCarteira[NomeCedente] = EmitenteSelecionado
			            ),
			            [Qtd Recebíveis Notas Consultadas]
			        )
			    )
			
			RETURN Resultado
			```
		formatString: 0
		displayFolder: Carteira\Quantidades
		lineageTag: d3434e3f-b632-45fd-94b1-e7bdf9481b53


	/// [Auxiliar] Informação completa da faixa em tooltip. Descrição detalhada.
	measure '_Info Faixa Completa Tooltip' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE('Parâmetro Faixa'[Valor])

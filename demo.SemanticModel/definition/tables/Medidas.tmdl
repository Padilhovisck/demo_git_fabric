	measure Intensidade_Monitoramento =
			
			VAR MinData = MIN(dCalendario[Data])
			VAR MaxData = MAX(dCalendario[Data])
			RETURN
			DIVIDE(
			    CALCULATE(
			        COUNTROWS(fDocumentos),
			        fDocumentos[DataConsulta] >= MinData &&
			        fDocumentos[DataConsulta] <= MaxData
			    ),
			    CALCULATE(
			        DISTINCTCOUNT(fDocumentos[ChaveNotaFiscal]),
			        fDocumentos[DataConsulta] >= MinData &&
			        fDocumentos[DataConsulta] <= MaxData
			    )
			)
			
			// Segmentar por:
			
			// Valor da nota (notas maiores são mais consultadas?)
			// Dias até vencimento
			// Emitente (alguns fornecedores geram mais dúvidas?)
			
			
			// Benchmark: Média de 1.0 = 1 consulta por nota. Acima = monitoramento intenso
		formatString: 0
		displayFolder: Notas Fiscais\Consultas
		lineageTag: 78c5ead4-5f7a-49bf-a717-ceb937f6cab2

	measure 'Ultima Data da Consulta' = ```
			
			VAR MinDataFiltrada = MIN(dCalendario[Data])
			VAR MaxDataFiltrada = MAX(dCalendario[Data])
			RETURN

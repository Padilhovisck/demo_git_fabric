	/// [Auxiliar] Percentual de emitentes por faixa dinâmica. Cálculo proporcional auxiliar.
	measure '_% Emitentes por Faixa Dinâmica' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE('Parâmetro Faixa'[Valor])
			
			// Obter os valores da faixa ATUAL (linha do eixo X)
			VAR FaixaAtual = SELECTEDVALUE('_Faixas Unificadas'[Faixa])
			VAR OrdemAtual = SELECTEDVALUE('_Faixas Unificadas'[Ordem])
			
			// Buscar Min/Max APENAS do tipo selecionado e faixa atual
			VAR MinFaixa = 
			    CALCULATE(
			        SELECTEDVALUE('_Faixas Unificadas'[Min]),
			        FILTER(
			            '_Faixas Unificadas',
			            '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado &&
			            '_Faixas Unificadas'[Faixa] = FaixaAtual
			        )
			    )
			
			VAR MaxFaixa = 
			    CALCULATE(
			        SELECTEDVALUE('_Faixas Unificadas'[Max]),
			        FILTER(
			            '_Faixas Unificadas',
			            '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado &&
			            '_Faixas Unificadas'[Faixa] = FaixaAtual
			        )
			    )
			
			// Se não encontrou Min/Max (faixa não existe para o tipo selecionado), retorna BLANK
			VAR ValidarFaixa = ISBLANK(MinFaixa) || ISBLANK(MaxFaixa)
			
			VAR TabelaCedentes = 
			    SUMMARIZE(
			        FILTER(
			            fCarteira,
			            RELATED(dNotas[ChaveNotaFiscal]) <> BLANK()
			        ),
			        fCarteira[CnpjCpfCedente],
			        "TotalNotas", [Qtd Cedentes por Cedente],
			        "TotalValor", [Total Carteira Notas Consultadas]
			    )
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = 0,
			        DIVIDE(
			            COUNTROWS(
			                FILTER(
			                    TabelaCedentes,
			                    [TotalNotas] >= MinFaixa && [TotalNotas] < MaxFaixa
			                )
			            ), [Qtd Cedentes Notas Existentes]
			        ),
			        DIVIDE(
			            COUNTROWS(
			                FILTER(
			                    TabelaCedentes,
			                    [TotalValor] >= MinFaixa && [TotalValor] < MaxFaixa
			                )
			                ),  [Qtd Cedentes Notas Existentes]
			            )
			        )    
			
			RETURN
			    IF(ValidarFaixa, BLANK(), Resultado)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: _Auxiliares\Cálculos Dinâmicos
		lineageTag: e8bfa408-c947-4ed9-9d79-45ef57b17b45

	/// [Auxiliar] Total geral exibido em card tooltip. Elemento de UI com valor agregado.
	measure '_Total Geral Card Tooltip' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE('Parâmetro Faixa'[Valor])
			VAR FaixaAtual = SELECTEDVALUE('_Faixas Unificadas'[Faixa])
			
			VAR MinFaixa = 
			    CALCULATE(
			        MIN('_Faixas Unificadas'[Min]),
			        ALL('_Faixas Unificadas'),
			        '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado,
			        '_Faixas Unificadas'[Faixa] = FaixaAtual
			    )
			
			VAR MaxFaixa = 
			    CALCULATE(
			        MAX('_Faixas Unificadas'[Max]),
			        ALL('_Faixas Unificadas'),
			        '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado,
			        '_Faixas Unificadas'[Faixa] = FaixaAtual
			    )
			
			// Tabela com todos os cedentes e seus totais
			VAR TabelaCedentes = 
			    ADDCOLUMNS(
			        VALUES(fCarteira[CnpjCpfCedente]),
			        "QtdNotas", 
			            CALCULATE(
			                [Qtd Cedentes por Cedente],
			                ALL('_Faixas Unificadas')
			            ),
			        "ValorTotal", 
			            CALCULATE(
			                [Total Carteira Notas Consultadas],
			                ALL('_Faixas Unificadas')
			            )
			    )
			
			// Filtrar cedentes que estão na faixa
			VAR CedentesFiltrados = 
			    FILTER(
			        TabelaCedentes,
			        IF(
			            TipoSelecionado = 0,
			            [QtdNotas] >= MinFaixa && [QtdNotas] < MaxFaixa,
			            [ValorTotal] >= MinFaixa && [ValorTotal] < MaxFaixa
			        )
			    )
			
			// Somar o total conforme o tipo
			VAR TotalGeral = 
			    IF(
			        TipoSelecionado = 0,
			        SUMX(CedentesFiltrados, [QtdNotas]),
			        SUMX(CedentesFiltrados, [ValorTotal])
			    )
			
			// Formatar o resultado
			VAR Resultado = 
			    IF(
			        TipoSelecionado = 0,
			        FORMAT(ROUND(TotalGeral, 0), "0"),
			        FORMAT(TotalGeral, "R$ #,##0")
			    )
			
			RETURN Resultado
			```
		displayFolder: _Auxiliares\Tooltips
		lineageTag: 235abbf9-3f7b-4fc6-b389-6981da5a83ef


	/// Valor total da carteira agrupado pelo último evento registrado. Usado para análise de status.
	measure 'Total Carteira pelo Último Evento' = ```
			
			VAR RaizContexto =
			    [_Raiz CNPJ Contexto]
			
			VAR TipoSelecionado =
			    SELECTEDVALUE ( tabTipoAgrupamento[Tipo], "Individual" )
			
			VAR EmitenteSelecionado =
			    SELECTEDVALUE ( tEmitente_Slicer[Emitente] )
			
			RETURN
			SUMX (
			    -- ITERA POR EVENTO (funciona para linha e total)
			    VALUES ( dEventos[CodigoEvento] ),
			    VAR CodigoEventoAtual =
			        dEventos[CodigoEvento]
			
			    VAR FiltroCarteiraComNota =
			        FILTER (
			            fCarteira,
			            NOT ISBLANK ( RELATED ( dNotas[ChaveNotaFiscal] ) )
			                && RELATED ( dNotas[CodigoEventoEfetivo] ) = CodigoEventoAtual
			        )
			
			    RETURN
			        COALESCE (
			            IF (
			                TipoSelecionado = "Grupo"
			                    && NOT ISBLANK ( RaizContexto ),
			                CALCULATE (
			                    SUM ( fCarteira[Valor] ),
			                    FiltroCarteiraComNota,
			                    fCarteira[CnpjCedenteRaiz] = RaizContexto
			                ),
			                IF (
			                    NOT ISBLANK ( EmitenteSelecionado ),
			                    CALCULATE (
			                        SUM ( fCarteira[Valor] ),
			                        FiltroCarteiraComNota,
			                        fCarteira[NomeCedente] = EmitenteSelecionado
			                    ),
			                    CALCULATE (
			                        SUM ( fCarteira[Valor] ),
			                        FiltroCarteiraComNota
			                    )
			                )
			            ),
			            0
			        )
			)
			
			```
		displayFolder: Carteira\Por Evento
		lineageTag: 5d106665-fec2-41c9-a228-19f8d1bb33a7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Valor total da carteira agrupado pelo tipo do último evento registrado. Análise de status atual.
	measure 'Total Carteira por Último Evento' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			// Captura os valores da linha atual (mantém a hierarquia)
			VAR CedenteNaLinha = SELECTEDVALUE(fCarteira[NomeCedente])
			VAR SacadoNaLinha = SELECTEDVALUE(fCarteira[NomeSacado])  // Ajuste conforme o nome real
			VAR ChavedaNota = SELECTEDVALUE(fCarteira[ChaveNotaFiscal])  // Ajuste conforme o nome real
			VAR Ndocumento = SELECTEDVALUE(fCarteira[Documento])  // Ajuste conforme o nome real
			
			RETURN
			CALCULATE(
			    SUM(fCarteira[Valor]),
			    FILTER(
			        ALL(fCarteira[CnpjCedenteRaiz], fCarteira[NomeCedente], fCarteira[NomeSacado], fCarteira[ChaveNotaFiscal], fCarteira[Documento]),
			
			        // Aplica filtro de Grupo/Individual
			        IF(
			            NOT(ISBLANK(RaizContexto)),
			            fCarteira[CnpjCedenteRaiz] = RaizContexto,
			            IF(
			                NOT(ISBLANK(EmitenteSelecionado)),
			                fCarteira[NomeCedente] = EmitenteSelecionado,
			                TRUE()
			            )
			        )
			        &&
			        // Mantém o filtro da linha se existir cedente
			        IF(
			            NOT(ISBLANK(CedenteNaLinha)),
			            fCarteira[NomeCedente] = CedenteNaLinha,
			            TRUE()
			        )
			        &&
			        // Mantém o filtro da linha se existir sacado
			        IF(NOT(ISBLANK(SacadoNaLinha)), 
			            fCarteira[NomeSacado]= SacadoNaLinha, 
			            TRUE()
			        )
			        &&
			        // Mantém o filtro da linha se existir nota
			        IF(NOT(ISBLANK(ChavedaNota)), 
			            fCarteira[ChaveNotaFiscal]= ChavedaNota, 
			            TRUE()
			        )
			        &&
			        // Mantém o filtro da linha se existir documento
			        IF(NOT(ISBLANK(Ndocumento)), 
			            fCarteira[Documento]= Ndocumento, 
			            TRUE()
			        )
			    )
			)
			```
		displayFolder: Eventos\Carteira
		lineageTag: 249b31eb-102b-482e-82a3-95ba9f9f4a5f


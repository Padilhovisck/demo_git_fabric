	/// [Auxiliar] Nome do cedente exibido em tooltip da faixa. Elemento de UI.
	measure '_Cedente na Faixa Tooltip' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE('Parâmetro Faixa'[Valor])
			VAR FaixaAtual = SELECTEDVALUE('_Faixas Unificadas'[Faixa])
			VAR CedenteAtual = SELECTEDVALUE(fCarteira[CnpjCpfCedente])
			
			// Buscar Min/Max da faixa atual
			VAR MinFaixa = 
			    CALCULATE(
			        SELECTEDVALUE('_Faixas Unificadas'[Min]),
			        FILTER(
			            ALL('_Faixas Unificadas'),
			            '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado &&
			            '_Faixas Unificadas'[Faixa] = FaixaAtual
			        )
			    )
			
			VAR MaxFaixa = 
			    CALCULATE(
			        SELECTEDVALUE('_Faixas Unificadas'[Max]),
			        FILTER(
			            ALL('_Faixas Unificadas'),
			            '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado &&
			            '_Faixas Unificadas'[Faixa] = FaixaAtual
			        )
			    )
			
			// Calcular a métrica do cedente atual
			VAR MetricaCedente = 
			    IF(
			        TipoSelecionado = 0,
			        CALCULATE(
			            [Qtd Cedentes por Cedente],
			            fCarteira[CnpjCpfCedente] = CedenteAtual
			        ),
			        CALCULATE(
			            [Total Carteira Notas Consultadas],
			            fCarteira[CnpjCpfCedente] = CedenteAtual
			        )
			    )
			
			// Verificar se está na faixa
			VAR EstaNaFaixa = 
			    MetricaCedente >= MinFaixa && MetricaCedente < MaxFaixa
			
			RETURN
			    IF(EstaNaFaixa, 1, 0)
			```
		formatString: 0
		displayFolder: _Auxiliares\Tooltips
		lineageTag: c7957028-7e45-4e48-8f70-94e05861f7e8

	/// [Auxiliar] Valor do cedente formatado para exibição (versão 4). Elemento de UI com formatação específica.
	measure '_Valor Cedente Formatado v4' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE('Parâmetro Faixa'[Valor])
			VAR CedenteAtual = SELECTEDVALUE(fCarteira[CnpjCpfCedente])
			VAR FaixaAtual = SELECTEDVALUE('_Faixas Unificadas'[Faixa])
			
			VAR MinFaixa = 
			    CALCULATE(
			        MIN('_Faixas Unificadas'[Min]),
			        ALL('_Faixas Unificadas'),
			        '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado,
			        '_Faixas Unificadas'[Faixa] = FaixaAtual
			    )
			
			VAR MaxFaixa = 
			    CALCULATE(
			        MAX('_Faixas Unificadas'[Max]),
			        ALL('_Faixas Unificadas'),
			        '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado,
			        '_Faixas Unificadas'[Faixa] = FaixaAtual
			    )
			
			VAR QtdNotas = 
			    CALCULATE(
			        [Qtd Cedentes por Cedente],
			        ALL('_Faixas Unificadas'),
			        fCarteira[CnpjCpfCedente] = CedenteAtual
			    )
			
			VAR ValorTotal = 
			    CALCULATE(
			        [Total Carteira Notas Consultadas],
			        ALL('_Faixas Unificadas'),
			        fCarteira[CnpjCpfCedente] = CedenteAtual
			    )
			
			VAR MetricaUsada = 
			    IF(TipoSelecionado = 0, QtdNotas, ValorTotal)
			
			VAR EstaNaFaixa = 
			    NOT ISBLANK(MetricaUsada) &&
			    NOT ISBLANK(MinFaixa) &&
			    NOT ISBLANK(MaxFaixa) &&
			    MetricaUsada >= MinFaixa && 
			    MetricaUsada < MaxFaixa
			
			VAR ValorFormatado = 
			    SWITCH(
			        TRUE(),
			        TipoSelecionado = 0, FORMAT(ROUND(QtdNotas, 0), "0"),
			        FORMAT(ValorTotal, "R$ #,##0")
			    )
			
			RETURN
			    IF(EstaNaFaixa, ValorFormatado, BLANK())
			```
		displayFolder: _Auxiliares\Tooltips
		lineageTag: 9c08a096-6e5d-46b8-abaa-73fcc0bbb7e3


	/// Número total de consultas de NFes realizadas no período. Indicador de atividade operacional.
	measure 'Total de Consultas Realizadas' = SUM(fDocumentos[ValorDuplicata])
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0

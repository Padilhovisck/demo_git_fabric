	/// Medida de teste para validar cálculos de carteira por evento. Uso interno/desenvolvimento.
	measure 'Teste Total Carteira por Último Evento' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			VAR FiltroNotas = 
			    FILTER(
			        fCarteira,
			        RELATED(dNotas[ChaveNotaFiscal]) <> BLANK()
			    )
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = "Grupo" && NOT(ISBLANK(RaizContexto)),
			        // Modo Grupo: filtra pela raiz
			        CALCULATE(
			            SUM(fCarteira[Valor]),
			            FILTER(
			                FiltroNotas,
			                fCarteira[CnpjCedenteRaiz] = RaizContexto
			            )
			        ),
			        // Modo Individual: aplica filtro do emitente selecionado
			        IF(
			            NOT(ISBLANK(EmitenteSelecionado)),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FILTER(
			                    FiltroNotas,
			                    fCarteira[NomeCedente] = EmitenteSelecionado
			                )
			            ),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FiltroNotas
			            )
			        )
			    )
			
			RETURN IF( Resultado = 0, BLANK(), Resultado )
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		displayFolder: Eventos\Carteira
		lineageTag: ba0dd49c-f843-4f24-ade3-207d7c6db82b


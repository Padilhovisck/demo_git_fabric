	/// Quantidade de cedentes agrupados por faixas de volume de notas. Análise de distribuição.
	measure 'Qtd Cedentes por Faixa de Notas' =
			
			VAR TabelaCedentes =
			    SUMMARIZE(
			        FILTER(
			            fCarteira,
			            RELATED(dNotas[ChaveNotaFiscal]) <> BLANK()
			        ),
			        fCarteira[CnpjCpfCedente],
			        "TotalCedente", [Qtd Cedentes por Cedente]
			    )
			VAR FaixaSelecionada = SELECTEDVALUE('_Faixas de Qtde Notas'[Faixa])
			VAR MinFaixa = SELECTEDVALUE('_Faixas de Qtde Notas'[Min])
			VAR MaxFaixa = SELECTEDVALUE('_Faixas de Qtde Notas'[Max])
			RETURN
			    COUNTROWS(
			        FILTER(
			            TabelaCedentes,
			            [TotalCedente] >= MinFaixa && [TotalCedente] < MaxFaixa
			        )
			    )
		formatString: 0
		displayFolder: Carteira\Análise de Cedentes
		lineageTag: 5984489c-8fab-4262-888c-c2e84787b2ed


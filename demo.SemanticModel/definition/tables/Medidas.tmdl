	/// Tempo médio em dias entre a emissão e a primeira consulta da nota. Indicador de agilidade operacional.
	measure 'Média Dias Primeira Consulta' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			VAR TabelaFiltrada =
			    FILTER(
			        fCarteira,
			        // Garante que existe uma nota correspondente
			        NOT(ISBLANK(
			            LOOKUPVALUE(
			                dNotas[ChaveNotaFiscal],
			                dNotas[ChaveNotaFiscal], fCarteira[ChaveNotaFiscal]
			            )
			        )) &&
			        NOT(ISBLANK(fCarteira[DataLancamento]))
			    )
			
			VAR TabelaComDias =
			    ADDCOLUMNS(
			        TabelaFiltrada,
			        "@DiasAteConsulta",
			        DATEDIFF(
			            fCarteira[DataLancamento],
			            LOOKUPVALUE(
			                dNotas[PrimeiraDataConsulta],
			                dNotas[ChaveNotaFiscal], fCarteira[ChaveNotaFiscal]
			            ),
			            DAY
			        )
			    )
			
			VAR TabelaFinal =
			    FILTER(
			        TabelaComDias,
			        // Filtro Grupo/Individual
			        IF(
			            TipoSelecionado = "Grupo" && NOT(ISBLANK(RaizContexto)),
			            fCarteira[CnpjCedenteRaiz] = RaizContexto,
			            IF(
			                NOT(ISBLANK(EmitenteSelecionado)),
			                fCarteira[NomeCedente] = EmitenteSelecionado,
			                TRUE()
			            )
			        )
			    )
			
			VAR MediaDias = 
			    AVERAGEX(
			        TabelaFinal,
			        [@DiasAteConsulta]
			    )
			
			RETURN
			    IF(
			        ISBLANK(MediaDias),
			        0,
			        MediaDias
			    )
			
			```
		displayFolder: Carteira\Análise Temporal
		lineageTag: 0eea5c34-7c6b-449b-bb5c-67f67c053693

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Quantidade de cedentes agrupados por faixas de valor. Análise de concentração financeira.
	measure 'Qtd Cedentes por Faixa de Valor' = ```
			
			VAR TabelaCedentes =
				SUMMARIZE(
			        FILTER(
			            fCarteira,
			            RELATED(dNotas[ChaveNotaFiscal]) <> BLANK()
			        ),
			        fCarteira[CnpjCpfCedente],
			        "TotalCedente", [Total da Carteira]
			    )
			VAR FaixaSelecionada = SELECTEDVALUE('_Faixas de Valores'[Faixa])
			VAR MinFaixa = SELECTEDVALUE('_Faixas de Valores'[Min])
			VAR MaxFaixa = SELECTEDVALUE('_Faixas de Valores'[Max])
			RETURN
			    COUNTROWS(
			        FILTER(
			            TabelaCedentes,
			            [TotalCedente] >= MinFaixa && [TotalCedente] < MaxFaixa
			        )
			    )
			
			```
		formatString: 0
		displayFolder: Carteira\Análise de Cedentes
		lineageTag: f88d35d9-6cd1-4ee9-a7d2-1db02cae549a

	/// [Auxiliar] Cálculo dinâmico de emitentes por faixa de valores. Usado em visuais interativos.
	measure '_Emitentes por Faixa Dinâmica' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE('Parâmetro Faixa'[Valor])
			
			// Obter os valores da faixa ATUAL (linha do eixo X)
			VAR FaixaAtual = SELECTEDVALUE('_Faixas Unificadas'[Faixa])
			VAR OrdemAtual = SELECTEDVALUE('_Faixas Unificadas'[Ordem])
			
			// Buscar Min/Max APENAS do tipo selecionado e faixa atual
			VAR MinFaixa = 
			    CALCULATE(
			        SELECTEDVALUE('_Faixas Unificadas'[Min]),
			        FILTER(
			            '_Faixas Unificadas',
			            '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado &&
			            '_Faixas Unificadas'[Faixa] = FaixaAtual
			        )
			    )
			
			VAR MaxFaixa = 
			    CALCULATE(
			        SELECTEDVALUE('_Faixas Unificadas'[Max]),
			        FILTER(
			            '_Faixas Unificadas',
			            '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado &&
			            '_Faixas Unificadas'[Faixa] = FaixaAtual
			        )
			    )
			
			// Se não encontrou Min/Max (faixa não existe para o tipo selecionado), retorna BLANK
			VAR ValidarFaixa = ISBLANK(MinFaixa) || ISBLANK(MaxFaixa)
			
			VAR TabelaCedentes = 
			    SUMMARIZE(
			        FILTER(
			            fCarteira,
			            RELATED(dNotas[ChaveNotaFiscal]) <> BLANK()
			        ),
			        fCarteira[CnpjCpfCedente],
			        "TotalNotas", [Qtd Cedentes por Cedente],
			        "TotalValor", [Total Carteira Notas Consultadas]
			    )
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = 0,
			        COUNTROWS(
			            FILTER(
			                TabelaCedentes,
			                [TotalNotas] >= MinFaixa && [TotalNotas] < MaxFaixa
			            )
			        ),
			        COUNTROWS(
			            FILTER(
			                TabelaCedentes,
			                [TotalValor] >= MinFaixa && [TotalValor] < MaxFaixa
			            )
			        )
			    )
			
			RETURN
			    IF(ValidarFaixa, BLANK(), Resultado)
			
			```
		formatString: 0
		displayFolder: _Auxiliares\Cálculos Dinâmicos
		lineageTag: 0163f0e9-359b-41b8-b5f9-3ac56836369a

	/// Localização geográfica (cidade/UF) do sacado. Usado em análises regionais.
	measure 'Praça do Sacado' =
			

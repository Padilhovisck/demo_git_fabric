	measure 'Ranking Dinâmico Top 5' = ```
			
			VAR Tipo =
			    SELECTEDVALUE('Parâmetro Eixo'[Parâmetro Eixo Pedido])
			
			RETURN
			SWITCH(
			    Tipo,
			
			    0,  -- UF
			        RANKX(
			            ALL(dNotas[UFDestinatario]),
			            [% do Total Geral N],
			            ,
			            DESC,
			            DENSE
			        ),
			
			    1,  -- Transportadora
			        RANKX(
			            FILTER(
			                ALL(dNotas[NomeTransportador]),
			                NOT ISBLANK(dNotas[NomeTransportador]) && TRIM(dNotas[NomeTransportador]) <> ""
			            ),
			            [% do Total Geral N],
			            ,
			            DESC,
			            DENSE
			        )
			)
			
			```
		formatString: 0
		displayFolder: Notas Fiscais\Faturamento
		lineageTag: 6b63d78c-813b-47ee-8fb8-2b6414ef6eb1

	measure 'Exibir Top 5' = ```
			
			VAR Tipo =
			    SELECTEDVALUE('Parâmetro Eixo'[Parâmetro Eixo Pedido])
			
			RETURN
			SWITCH(
			    Tipo,
			
			    0,
			        IF([Ranking Dinâmico Top 5] <= 5, 1, 0),
			
			    1,
			        IF(
			            NOT ISBLANK(SELECTEDVALUE(dNotas[NomeTransportador]))
			                && TRIM(SELECTEDVALUE(dNotas[NomeTransportador])) <> ""
			                && [Ranking Dinâmico Top 5] <= 5,
			            1,
			            0
			        )
			)
			
			```
		formatString: 0
		displayFolder: Notas Fiscais\Faturamento
		lineageTag: 12832018-09b9-423a-9497-7d22cbbe60ff


		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Soma do valor total de todos os recebíveis na carteira. Representa o valor bruto total da carteira de NFes.
	measure 'Total da Carteira' = SUM(fCarteira[Valor])
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		displayFolder: Carteira\Valores Totais
		lineageTag: 90d152d4-0ba9-4bbd-9342-3e9b39b7b5dd

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	/// Valor total da carteira considerando apenas as notas fiscais que foram consultadas. Útil para medir o percentual de cobertura das consultas.
	measure 'Total Carteira Notas Consultadas' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			VAR FiltroNotas = 
			    FILTER(
			        fCarteira,
			        NOT ISBLANK(RELATED(dNotas[ChaveNotaFiscal]))
			    )
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = "Grupo" && NOT ISBLANK(RaizContexto),
			        CALCULATE(
			            SUM(fCarteira[Valor]),
			            FILTER(
			                FiltroNotas,
			                fCarteira[CnpjCedenteRaiz] = RaizContexto
			            )
			        ),
			        IF(
			            NOT ISBLANK(EmitenteSelecionado),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FILTER(
			                    FiltroNotas,
			                    fCarteira[NomeCedente] = EmitenteSelecionado
			                )
			            ),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FiltroNotas
			            )
			        )
			    )
			
			RETURN COALESCE(Resultado, 0)
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		displayFolder: Carteira\Valores Totais
		lineageTag: c2d48ad3-dae2-47bc-9c28-4fbc31a412a3

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	/// Percentual de notas que foram consultadas em relação ao total da carteira. Indicador de cobertura de consultas.
	measure '% Consultas Realizadas da Carteira' = DIVIDE([Total Carteira Notas Consultadas], [Total Dinâmico])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Carteira\Percentuais
		lineageTag: 008e5f53-337e-40bd-b348-f48745c0454f

	/// Percentual do valor vencido em relação ao total da carteira. KPI de risco de inadimplência.
	measure '% Total Vencidos Notas Existentes' =
			
			VAR ResultadoPercentual = DIVIDE([Total Vencidos Notas Existentes], [Total Dinâmico], 0)
			RETURN ResultadoPercentual
			    // "(vencidos) | " & FORMAT(ResultadoPercentual, "0.0%")
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Carteira\Percentuais
		lineageTag: ab98388f-ee49-4275-aad2-d91b3595850a

	/// Medida dinâmica que alterna entre diferentes totais com base em seleções do usuário. Utilizada em visuais interativos.
	measure 'Total Dinâmico' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = "Grupo" && NOT ISBLANK(RaizContexto),
			        CALCULATE(
			            [Total da Carteira],
			            REMOVEFILTERS(fCarteira[NomeCedente]),
			            fCarteira[CnpjCedenteRaiz] = RaizContexto
			        ),
			        IF(
			            NOT ISBLANK(EmitenteSelecionado),
			            CALCULATE(
			                [Total da Carteira],
			                fCarteira[NomeCedente] = EmitenteSelecionado
			            ),
			            [Total da Carteira]
			        )
			    )
			
			RETURN Resultado
			```

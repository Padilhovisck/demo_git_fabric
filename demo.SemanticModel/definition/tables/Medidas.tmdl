table Medidas
	lineageTag: 4586774b-3a0a-4fec-9fb7-538e959ac9bf

	/// Identifica os principais emitentes de NFes por volume ou valor. Usado em rankings e análises de concentração.
	measure 'Carteira Top Emitentes' = ```
			
			
			VAR _N = 'Top 5 Emitentes'[Valor Segmentador Top N]
			
			VAR _Tops = 
			WINDOW(
			    1, ABS,
			    _N, ABS,
			    ALLSELECTED(topEmitentesdaNota[Emitente]),
			    ORDERBY([Total de Consultas Realizadas], DESC)
			)
			
			VAR _Outros = 
			WINDOW(
			    _N + 1, ABS,
			    -1, ABS,
			    ALLSELECTED(topEmitentesdaNota[Emitente]),
			    ORDERBY([Total de Consultas Realizadas], DESC)
			)
			
			VAR _TopsValor = 
			CALCULATE(
			    [Total de Consultas Realizadas],
			    KEEPFILTERS(_Tops)
			)
			
			VAR _OutrosValor = 
			CALCULATE(
			    [Total de Consultas Realizadas],
			    _Outros
			)
			
			VAR _Resultado = 
			IF(
			    SELECTEDVALUE(topEmitentesdaNota[Emitente]) = "Outros",
			    _OutrosValor,
			    _TopsValor
			)
			
			RETURN _Resultado
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		displayFolder: Notas Fiscais\Análise de Emitentes
		lineageTag: c9471ea1-5d04-4d4a-b894-26a5c0b3e429

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	/// Classifica os cedentes em categorias (Top N) baseado em critérios de volume ou valor.
	measure 'Classificador Top Cedentes' = ```
			
			
			VAR _Relation = 
			FILTER(
			    ALLSELECTED(topEmitentesdaNota[Emitente]),
			    topEmitentesdaNota[Emitente] <> "Outros"
			    && [Carteira Top Emitentes] > 0 -- Excluir emitentes com valor zero
			)
			
			VAR _Rank = 
			RANK(
			    DENSE,
			    _Relation,
			    ORDERBY([Carteira Top Emitentes], DESC)
			)
			
			VAR _Resultado = 
			IF(
			    SELECTEDVALUE(topEmitentesdaNota[Emitente]) = "Outros"
			        && [Carteira Top Emitentes],
			        999999,
			    _Rank
			)
			
			RETURN _Resultado
			
			
			```
		displayFolder: Notas Fiscais\Análise de Emitentes
		lineageTag: 195122ce-71f6-40eb-995d-5413a56445cb

		annotation PBI_FormatHint = {"isGeneralNumber":true}


	/// Valor total dos recebíveis que já passaram da data de vencimento. Indicador de risco de inadimplência.
	measure 'Total Vencidos Notas Existentes' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			VAR DataHoje = TODAY()
			
			VAR FiltroVencidos = 
			    FILTER(
			        fCarteira,
			        fCarteira[DataVencimento] < DataHoje
			        && NOT ISBLANK(RELATED(dNotas[ChaveNotaFiscal]))
			    )
			
			VAR Resultado = 
			    IF(
			        TipoSelecionado = "Grupo" && NOT ISBLANK(RaizContexto),
			        CALCULATE(
			            SUM(fCarteira[Valor]),
			            FILTER(
			                FiltroVencidos,
			                fCarteira[CnpjCedenteRaiz] = RaizContexto
			            )
			        ),
			        IF(
			            NOT ISBLANK(EmitenteSelecionado),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FILTER(
			                    FiltroVencidos,
			                    fCarteira[NomeCedente] = EmitenteSelecionado
			                )
			            ),
			            CALCULATE(
			                SUM(fCarteira[Valor]),
			                FiltroVencidos
			            )
			        )
			    )
			
			RETURN COALESCE(Resultado, 0)
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0

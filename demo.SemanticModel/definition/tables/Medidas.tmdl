	measure '_Filtro Preponderancia Apply' =
			
			VAR Sel = SELECTEDVALUE('Filtro Ultrapassagem'[Filtro], "Todos")
			VAR Qtde =
			    CALCULATE(
			        COUNTROWS(dEventos),
			        dEventos[PreponderanciaCodigo] = 1
			    )
			RETURN
			IF(
			    Sel = "Todos" ||
			    (Sel = "Sim" && Qtde > 0) ||
			    (Sel = "Não" && Qtde = 0),
			    1,
			    0
			)

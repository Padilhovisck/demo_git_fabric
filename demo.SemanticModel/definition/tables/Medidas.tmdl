	measure '% Variação Carteira vs Data Anterior' = ```
			
			VAR DataAtual =
			    MAX ( _dDataCarga[DataCarga] )
			
			VAR DataAnterior =
			    CALCULATE (
			        MAX ( fCarteira[DataCarga] ),
			        FILTER (
			            ALL ( fCarteira ),
			            fCarteira[DataCarga] < DataAtual
			        )
			    )
			
			VAR ValorAtual =
			    [Total Dinâmico]
			
			VAR ValorAnterior =
			    CALCULATE (
			        [Total Dinâmico],
			        REMOVEFILTERS ( _dDataCarga[DataCarga] ),
			        TREATAS ( { DataAnterior }, fCarteira[DataCarga] )
			    )
			
			
			RETURN DIVIDE ( ValorAtual - ValorAnterior, ValorAnterior )
			
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Carteira\Percentuais
		lineageTag: cb7c5b71-7177-4f01-ad66-cb26b3a830ca

	measure 'KPI Variação Carteira' = ```
			
			VAR ValorPct = [% Variação Carteira vs Data Anterior]
			VAR Sinal =
			    SWITCH(
			        TRUE(),
			        ISBLANK(ValorPct), BLANK(),
			        ValorPct > 0, "▲ ",
			        ValorPct < 0, "▼ ",
			        "▬ "
			    )
			RETURN
			    IF(
			        ISBLANK(ValorPct),
			        "0.0%",
			        Sinal & FORMAT(ValorPct, "0.0%") //& " vs anterior"
			    )
			
			```
		displayFolder: Carteira\Análise Temporal
		lineageTag: 9470feaa-1b87-4ba7-b483-1d75abe09a1e

	measure 'KPI Variação Carteira Cor' = ```
			

	/// Valor total de notas a vencer no período selecionado. Previsão de recebimentos.
	measure 'Total a Vencer no Período' =
			
			VAR UltimaDataContexto = MAX(dCalendario[Data])
			RETURN
			CALCULATE(
			    [Total de Consultas Realizadas],
			    fDocumentos[DataVencimento] > UltimaDataContexto
			)

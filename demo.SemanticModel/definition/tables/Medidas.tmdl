	/// [Auxiliar] Valor do cedente (versão 5 - mais recente). Base para cálculos de cedente.
	measure '_Valor Cedente v5' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE('Parâmetro Faixa'[Valor])
			VAR CedenteAtual = SELECTEDVALUE(fCarteira[CnpjCpfCedente])
			VAR FaixaAtual = SELECTEDVALUE('_Faixas Unificadas'[Faixa])
			
			VAR MinFaixa =
			    CALCULATE(
			        MIN('_Faixas Unificadas'[Min]),
			        ALL('_Faixas Unificadas'),
			        '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado,
			        '_Faixas Unificadas'[Faixa] = FaixaAtual
			    )
			
			VAR MaxFaixa =
			    CALCULATE(
			        MAX('_Faixas Unificadas'[Max]),
			        ALL('_Faixas Unificadas'),
			        '_Faixas Unificadas'[TipoFaixa] = TipoSelecionado,
			        '_Faixas Unificadas'[Faixa] = FaixaAtual
			    )
			
			VAR QtdNotas =
			    CALCULATE(
			        [Qtd Cedentes por Cedente],
			        ALL('_Faixas Unificadas'),
			        fCarteira[CnpjCpfCedente] = CedenteAtual
			    )
			
			VAR ValorTotal =
			    CALCULATE(
			        [Total Carteira Notas Consultadas],
			        ALL('_Faixas Unificadas'),
			        fCarteira[CnpjCpfCedente] = CedenteAtual
			    )
			
			VAR MetricaUsada =
			    IF(TipoSelecionado = 0, QtdNotas, ValorTotal)
			
			VAR EstaNaFaixa =
			    NOT ISBLANK(MetricaUsada)
			        && NOT ISBLANK(MinFaixa)
			        && NOT ISBLANK(MaxFaixa)
			        && MetricaUsada >= MinFaixa
			        && MetricaUsada < MaxFaixa
			
			RETURN
			    IF(EstaNaFaixa, MetricaUsada)
			
			```
		displayFolder: _Auxiliares\Cálculos Dinâmicos
		lineageTag: a500718e-c5f9-4659-8efe-1f8a85577b0c

		formatStringDefinition = ```
				IF(
				    SELECTEDVALUE('Parâmetro Faixa'[Valor]) = 0,
				    "0",
				    "R$ #,##0"
				)
				
				```

	/// Quantidade total de notas que possuem eventos registrados. Base para análise de rastreamento.
	measure 'Qtd Total de Notas Eventos' = ```
			
			VAR RaizFiltro = [_Raiz CNPJ Contexto Eventos]
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer_Notas[Emitente])
			
			VAR NotasComFiltro = 
			    CALCULATETABLE(
			        VALUES(fDocumentos[ChaveNotaFiscal]),
			        IF(NOT(ISBLANK(RaizFiltro)), 
			            fDocumentos[CnpjCedenteRaiz] = RaizFiltro,
			            IF(NOT(ISBLANK(EmitenteSelecionado)),
			                fDocumentos[NomeFantasiaEmitente] = EmitenteSelecionado,
			                TRUE()
			            )
			        )
			    )
			
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(fEventos[ChaveNotaFiscal]),
			    TREATAS(NotasComFiltro, fEventos[ChaveNotaFiscal])
			)
			```
		formatString: 0
		displayFolder: Eventos\Quantidades
		lineageTag: 7da70688-29f9-45f4-9d7b-85a2883828e2


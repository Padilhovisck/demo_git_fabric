	/// [Auxiliar] Filtro aplicado em matrizes para agrupar dados. Controle de contexto de cálculo.
	measure '_Filtro Matriz Grupo' = ```
			
			VAR RaizContexto = [_Raiz CNPJ Contexto]
			VAR EmitenteSelecionado = SELECTEDVALUE(tEmitente_Slicer[Emitente])
			VAR CedenteNaLinha = SELECTEDVALUE(fCarteira[NomeCedente])
			
			RETURN
			    IF(
			        ISBLANK(EmitenteSelecionado),
			        1, // Sem filtro, mostra tudo
			        IF(
			            NOT(ISBLANK(RaizContexto)),
			            // Modo Grupo
			            VAR RaizNaLinha = 
			                CALCULATE(
			                    MIN(fCarteira[CnpjCedenteRaiz]),
			                    fCarteira[NomeCedente] = CedenteNaLinha
			                )
			            RETURN IF(RaizNaLinha = RaizContexto, 1, BLANK()),
			            // Modo Individual
			            IF(CedenteNaLinha = EmitenteSelecionado, 1, BLANK())
			        )
			    )
			```
		formatString: 0
		displayFolder: _Auxiliares\Contexto e Filtros
		lineageTag: c024e586-0391-43a9-8520-d3194af95915

	/// [Auxiliar] Extração da raiz do CNPJ para agrupamento por grupo econômico. Contexto de análise.
	measure '_Raiz CNPJ Contexto' = ```
			
			VAR TipoSelecionado = SELECTEDVALUE(tabTipoAgrupamento[Tipo], "Individual")
